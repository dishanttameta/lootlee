    "custom_liquid_rPdT6A": {
      "type": "custom-liquid",
      "name": "reviews",
      "settings": {
        "custom_liquid": "<div class=\"reviews-section\">\n\n  <h2 class=\"offer-title\">CUSTOMER REVIEWS</h2>\n\n  <div class=\"reviews-grid\">\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Rahul S.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">\n        Great quality shirt. Fabric feels premium and fitting is perfect.\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Priya M.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">\n        Loved the design and comfort. Definitely ordering again.\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Aman K.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">\n        Looks exactly like the pictures. Good value for money.\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Sneha P.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">\n        Soft fabric and stylish fit. Got compliments on the first day.\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Vikram R.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">\n        Delivery was quick and the quality exceeded expectations.\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Neha T.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">\n        Very comfortable for daily wear. Color is exactly as shown.\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Arjun D.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">\n        Excellent stitching and premium feel. Worth every rupee.\n      </div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Kavya J.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">\n        One of the best online purchases I've made recently.\n      </div>\n    </div>\n\n  </div>\n\n</div>\n\n<style>\n.reviews-section{\n  max-width:1400px;\n  margin:50px auto;\n  padding:0 20px;\n}\n\n.offer-title{\n  text-align:center;\n  font-size:38px;\n  font-weight:700;\n  letter-spacing:2px;\n  color:#111;\n  margin-bottom:30px;\n}\n\n.reviews-grid{\n  display:grid;\n  grid-template-columns:repeat(4,1fr);\n  gap:20px;\n}\n\n.review-card{\n  background:#fff;\n  border:1px solid #e5e5e5;\n  border-radius:12px;\n  padding:22px;\n  min-height:180px;\n  transition:.3s ease;\n}\n\n.review-card:hover{\n  transform:translateY(-3px);\n  box-shadow:0 8px 20px rgba(0,0,0,.08);\n}\n\n.review-name{\n  font-size:18px;\n  font-weight:600;\n  color:#111;\n  margin-bottom:10px;\n}\n\n.review-stars{\n  color:#f5a623;\n  font-size:18px;\n  margin-bottom:12px;\n  letter-spacing:2px;\n}\n\n.review-text{\n  color:#555;\n  font-size:15px;\n  line-height:1.7;\n}\n\n/* Mobile */\n@media screen and (max-width:768px){\n\n  .reviews-grid{\n    grid-template-columns:repeat(2,1fr);\n    gap:12px;\n  }\n\n  .offer-title{\n    font-size:28px;\n    margin-bottom:20px;\n  }\n\n  .review-card{\n    padding:15px;\n    min-height:160px;\n  }\n\n  .review-name{\n    font-size:15px;\n  }\n\n  .review-stars{\n    font-size:14px;\n  }\n\n  .review-text{\n    font-size:13px;\n    line-height:1.5;\n  }\n}\n</style>",
