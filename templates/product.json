            "custom_liquid_6aaBcD": {
              "type": "custom-liquid",
              "name": "pincode checker",
              "disabled": true,
              "settings": {
                "custom_liquid": "<div class=\"lootlee-pincode-checker\">\n<h4>Check Delivery Availability</h4>\n  <div class=\"pincode-box\">\n    <input\n      type=\"text\"\n      id=\"lootlee-pincode\"\n      placeholder=\"Enter Pincode\"\n      maxlength=\"6\"\n    >\n    <button id=\"lootlee-check-btn\">Check</button>\n  </div>\n\n  <div id=\"lootlee-result\"></div>\n</div>\n\n<style>\n.lootlee-pincode-checker {\n  margin: 20px 0;\n}\n\n.pincode-box {\n  display: flex;\n  gap: 10px;\n}\n\n#lootlee-pincode {\n  flex: 1;\n  padding: 12px;\n  border: 1px solid #ddd;\n  border-radius: 4px;\n}\n\n#lootlee-check-btn {\n  padding: 12px 18px;\n  border: none;\n  cursor: pointer;\n  background: #000;\n  color: #fff;\n  border-radius: 4px;\n}\n\n#lootlee-result {\n  margin-top: 12px;\n  font-size: 14px;\n  line-height: 1.5;\n}\n</style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n\n  const button = document.getElementById('lootlee-check-btn');\n\n  button.addEventListener('click', async function() {\n\n    const pincode = document.getElementById('lootlee-pincode').value.trim();\n    const result = document.getElementById('lootlee-result');\n\n    if (!/^[1-9][0-9]{5}$/.test(pincode)) {\n      result.innerHTML =\n        '❌ Product unavailable at ' + pincode;\n      result.style.color = '#d32f2f';\n      return;\n    }\n\n    result.innerHTML = 'Checking...';\n    result.style.color = '#666';\n\n    try {\n\n      const response = await fetch(\n        'https://api.postalpincode.in/pincode/' + pincode\n      );\n\n      const data = await response.json();\n\n      if (\n        data &&\n        data[0] &&\n        data[0].Status === 'Success' &&\n        data[0].PostOffice &&\n        data[0].PostOffice.length > 0\n      ) {\n\n        const city = data[0].PostOffice[0].District;\n        const state = data[0].PostOffice[0].State;\n\n        result.innerHTML =\n          '✅ Product will be available within 5–7 Business Days<br>' +\n          '<small>📍 ' + city + ', ' + state + '</small>';\n\n        result.style.color = '#2e7d32';\n\n      } else {\n\n        result.innerHTML =\n          '❌ Product unavailable at ' + pincode;\n\n        result.style.color = '#d32f2f';\n      }\n\n    } catch (error) {\n\n      result.innerHTML =\n        '❌ Unable to verify pincode. Please try again.';\n\n      result.style.color = '#d32f2f';\n    }\n\n  });\n\n});\n</script>"
              },
