                "custom_liquid_EGQTQG": {
                  "type": "custom-liquid",
                  "name": "t:names.custom_liquid",
                  "settings": {
                    "custom_liquid": "<div class=\"lootlee-share-product\">\n  <button id=\"share-product-btn\" type=\"button\">\n    \n    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\"\n        d=\"M8.59 13.51L15.42 17.49M15.41 6.51L8.59 10.49M18 5a3 3 0 110 6 3 3 0 010-6zM6 9a3 3 0 110 6 3 3 0 010-6zM18 15a3 3 0 110 6 3 3 0 010-6z\"/>\n    </svg>\n\n    <span>Share</span>\n\n  </button>\n</div>\n\n<script>\ndocument.getElementById('share-product-btn')?.addEventListener('click', async () => {\n  const productUrl = window.location.href;\n\n  if (navigator.share) {\n    try {\n      await navigator.share({\n        title: document.title,\n        url: productUrl\n      });\n    } catch (err) {}\n  } else {\n    navigator.clipboard.writeText(productUrl);\n    alert('Product link copied!');\n  }\n});\n</script>\n\n<style>\n.lootlee-share-product {\n  width: 100%;\n}\n\n#share-product-btn {\n  display: inline-flex;\n  align-items: center;      /* Vertical center */\n  justify-content: center;  /* Horizontal center */\n  gap: 8px;\n\n  background: transparent;\n  border: none;\n  cursor: pointer;\n\n  padding: 0;\n  margin: 0;\n\n  line-height: 1;\n  font-size: 14px;\n}\n\n#share-product-btn span {\n  display: flex;\n  align-items: center;\n  line-height: 1;\n}\n\n#share-product-btn svg {\n  flex-shrink: 0;\n}\n</style>"
