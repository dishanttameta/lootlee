    "custom_liquid_kaMdnG": {
      "type": "custom-liquid",
      "name": "Custom Liquid - reviews",
      "settings": {
        "custom_liquid": "<div class=\"reviews-slider\">\n  <div class=\"offer-title\">\n    Customer Reviews\n  </div>\n\n  <div class=\"reviews-track\">\n\n    <!-- Reviews -->\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Rahul S.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Great quality shirt. Fabric feels premium and fitting is perfect.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Priya M.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Loved the design and comfort. Definitely ordering again.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Aman K.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Looks exactly like the pictures. Good value for money.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Sneha P.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Soft fabric and stylish fit. Got compliments on the first day.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Vikram R.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Delivery was quick and the shirt quality exceeded expectations.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Neha T.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Very comfortable for daily wear. Color is exactly as shown.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Arjun D.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Excellent stitching and premium feel. Worth every rupee.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Kavya J.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">One of the best online purchases I've made recently.</div>\n    </div>\n\n    <!-- Duplicate Reviews For Infinite Scroll -->\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Rahul S.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Great quality shirt. Fabric feels premium and fitting is perfect.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Priya M.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Loved the design and comfort. Definitely ordering again.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Aman K.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Looks exactly like the pictures. Good value for money.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Sneha P.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Soft fabric and stylish fit. Got compliments on the first day.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Vikram R.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Delivery was quick and the shirt quality exceeded expectations.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Neha T.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Very comfortable for daily wear. Color is exactly as shown.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Arjun D.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">Excellent stitching and premium feel. Worth every rupee.</div>\n    </div>\n\n    <div class=\"review-card\">\n      <div class=\"review-name\">Kavya J.</div>\n      <div class=\"review-stars\">★★★★★</div>\n      <div class=\"review-text\">One of the best online purchases I've made recently.</div>\n    </div>\n\n  </div>\n</div>\n\n<style>\n.reviews-slider{\n  width:100%;\n  overflow:hidden;\n  margin:20px 0;\n}\n\n.offer-title{\n  font-weight:600;\n  color:#000;\n  margin-bottom:20px;\n  text-align:center;\n  width:100%;\n  display:block;\n  font-size:32px;\n  text-transform:uppercase;\n  letter-spacing:1px;\n}\n\n.reviews-track{\n  display:flex;\n  gap:15px;\n  width:max-content;\n  animation:reviewScroll 55s linear infinite;\n}\n\n.review-card{\n  width:280px;\n  min-width:280px;\n  background:#fff;\n  border:1px solid #e5e5e5;\n  border-radius:12px;\n  padding:18px;\n  box-sizing:border-box;\n}\n\n.review-name{\n  font-size:16px;\n  font-weight:700;\n  color:#111;\n  margin-bottom:8px;\n}\n\n.review-stars{\n  color:#f5a623;\n  font-size:18px;\n  margin-bottom:12px;\n  letter-spacing:2px;\n}\n\n.review-text{\n  color:#555;\n  font-size:14px;\n  line-height:1.6;\n}\n\n@keyframes reviewScroll{\n  from{\n    transform:translateX(0);\n  }\n  to{\n    transform:translateX(-50%);\n  }\n}\n\n.reviews-slider:hover .reviews-track{\n  animation-play-state:paused;\n}\n\n@media(max-width:768px){\n\n  .offer-title{\n    font-size:24px;\n  }\n\n  .review-card{\n    width:240px;\n    min-width:240px;\n  }\n}\n</style>",
