{% liquid
  assign is_first_section = false
  if section.index == 1 or section.index == 0 or section.index == blank
    assign is_first_section = true
  endif
%}

<!-- Section Index: {{ section.index }} -->

<div class="auto-banner-slider" id="Slider-{{ section.id }}">
  <div class="slider-track">
    {% for block in section.blocks %}
      {% liquid
        assign loading_attr = 'lazy'
        assign fetchpriority_attr = 'auto'
        if forloop.first and is_first_section
          assign loading_attr = 'eager'
          assign fetchpriority_attr = 'high'
        endif
      %}
      <div class="slide" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}">
        {%- endif -%}

        {%- if block.settings.desktop_image != blank -%}
          <img
            class="desktop-banner"
            src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="{{ loading_attr }}"
            {% if fetchpriority_attr == 'high' %}fetchpriority="high"{% endif %}
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
          >
        {%- else -%}
          {%- assign placeholder_image = 'lifestyle-1' -%}
          {{ placeholder_image | placeholder_svg_tag: 'desktop-banner placeholder-svg' }}
        {%- endif -%}

        {%- if block.settings.mobile_image != blank -%}
          <img
            class="mobile-banner"
            src="{{ block.settings.mobile_image | image_url: width: 800 }}"
            alt="{{ block.settings.mobile_image.alt | escape }}"
            loading="{{ loading_attr }}"
            {% if fetchpriority_attr == 'high' %}fetchpriority="high"{% endif %}
            width="{{ block.settings.mobile_image.width }}"
            height="{{ block.settings.mobile_image.height }}"
          >
        {%- else -%}
          {%- if block.settings.desktop_image != blank -%}
            <img
              class="mobile-banner"
              src="{{ block.settings.desktop_image | image_url: width: 800 }}"
              alt="{{ block.settings.desktop_image.alt | escape }}"
              loading="{{ loading_attr }}"
              {% if fetchpriority_attr == 'high' %}fetchpriority="high"{% endif %}
              width="{{ block.settings.desktop_image.width }}"
              height="{{ block.settings.desktop_image.height }}"
            >
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'mobile-banner placeholder-svg' }}
          {%- endif -%}
        {%- endif -%}

        {%- if block.settings.link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {% endfor %}
  </div>
</div>

<style>
#Slider-{{ section.id }}.auto-banner-slider {
  width: 100%;
  overflow: hidden;
}

#Slider-{{ section.id }}.auto-banner-slider .slider-track {
  display: flex;
  width: {{ section.blocks.size | times: 100 }}%;
  transition: transform .6s ease;
}

#Slider-{{ section.id }}.auto-banner-slider .slide {
  width: {{ 100.0 | divided_by: section.blocks.size }}%;
  flex-shrink: 0;
}

#Slider-{{ section.id }}.auto-banner-slider img {
  width: 100%;
  display: block;
  height: auto;
}

/* Desktop */
#Slider-{{ section.id }}.auto-banner-slider .mobile-banner {
  display: none !important;
}

#Slider-{{ section.id }}.auto-banner-slider .desktop-banner {
  display: block !important;
}

/* Mobile */
@media screen and (max-width: 768px) {
  #Slider-{{ section.id }}.auto-banner-slider .desktop-banner {
    display: none !important;
  }

  #Slider-{{ section.id }}.auto-banner-slider .mobile-banner {
    display: block !important;
  }
}
</style>

<script>
(function() {
  const slider = document.querySelector('#Slider-{{ section.id }}');
  if (!slider) return;

  const track = slider.querySelector('.slider-track');
  if (!track) return;

  const slidesCount = {{ section.blocks.size }};
  if (slidesCount <= 1) return;

  let current = 0;
  const autoplaySpeed = {{ section.settings.autoplay_speed | default: 5 }} * 1000;

  setInterval(function() {
    current = (current + 1) % slidesCount;
    const translateAmount = current * -(100 / slidesCount);
    track.style.transform = `translateX(${translateAmount}%)`;
  }, autoplaySpeed);
})();
</script>

{% schema %}
{
  "name": "Auto Banner Slider",
  "tag": "section",
  "class": "section-auto-banner-slider",
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Auto Banner Slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
