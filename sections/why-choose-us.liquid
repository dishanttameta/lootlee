<div class="why-choose-us section-{{ section.id }} page-width" style="margin-top: {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px; padding: 0 20px;">
  {% if section.settings.title != blank %}
    <div style="margin-bottom: 30px;">
      <h2 style="font-size: 28px; font-weight: 300; margin: 0; color: var(--color-foreground);">{{ section.settings.title }}</h2>
    </div>
  {% endif %}

  <div class="why-choose-us-grid">
    {% for block in section.blocks %}
      <div class="why-choose-us-col" {{ block.shopify_attributes }}>
        <div class="why-choose-us-image-wrapper">
          

          <!-- Feature Image -->
          {% if block.settings.image != blank %}
            <img 
              src="{{ block.settings.image | image_url: width: 600 }}" 
              alt="{{ block.settings.title | escape }}"
              loading="lazy"
              width="600"
              height="600"
              style="width: 100%; height: 100%; display: block; object-fit: cover;"
            >
          {% else %}
            <!-- Placeholder Unsplash Image if empty -->
            <img 
              src="{{ block.settings.placeholder_url }}" 
              alt="{{ block.settings.title | escape }}"
              loading="lazy"
              width="600"
              height="545"
              style="width: 100%; height: 100%; display: block; object-fit: cover;"
            >
          {% endif %}
        </div>

        {% if block.settings.title != blank %}
          <h4 class="why-choose-us-title">{{ block.settings.title }}</h4>
        {% endif %}
        
        {% if block.settings.description != blank %}
          <span class="why-choose-us-desc">{{ block.settings.description }}</span>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .why-choose-us-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .why-choose-us-col {
    display: flex;
    flex-direction: column;
    text-align: left;
  }
  .why-choose-us-image-wrapper {
    position: relative;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 16px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    aspect-ratio: 1.1 / 1;
  }
  .why-choose-us-title {
    font-size: 20px;
    font-weight: 300;
    margin: 0 0 6px 0;
    color: var(--color-foreground);
  }
  .why-choose-us-desc {
    font-size: 13px;
    color: var(--color-foreground-secondary);
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Why Choose Us"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 100,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Feature Image"
        },
        {
          "type": "text",
          "id": "placeholder_url",
          "label": "Fallback Image URL (Unsplash)",
          "default": "https://images.unsplash.com/photo-1566576721346-d4a3b4eaeb55?auto=format&fit=crop&w=600&q=80"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "Feature Heading"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Feature Description",
          "default": "Feature detail subtext goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "We Processing Orders",
            "description": "Fast and reliable order fulfillment with real-time tracking",
            "placeholder_url": "https://images.unsplash.com/photo-1566576721346-d4a3b4eaeb55?auto=format&fit=crop&w=600&q=80"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Best Delivery Experience",
            "description": "Nationwide shipping with guaranteed on-time delivery",
            "placeholder_url": "https://images.unsplash.com/photo-1595246140625-573b715d11dc?auto=format&fit=crop&w=600&q=80"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Trusted by 1000+ Users",
            "description": "Join thousands of satisfied customers worldwide",
            "placeholder_url": "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?auto=format&fit=crop&w=600&q=80"
          }
        }
      ]
    }
  ]
}
{% endschema %}
