.newsletter-input {\n  width: 100%;\n  height: 46px;\n  border: 1px solid #ccc;\n  padding: 0 15px;\n  margin-bottom: 18px;\n  background: transparent;\n}\n\n.newsletter-btn {\n  background: #000;\n  color: #fff;\n  border: none;\n  padding: 13px 42px;\n  font-weight: 600;\n  cursor: pointer;\n}\n\n.newsletter-btn:hover {\n  opacity: .9;\n}\n\n@media(max-width:990px){\n  .custom-footer-inner{\n    grid-template-columns:1fr;\n    gap:35px;\n  }\n}\n</style>\n\n<div class=\"custom-footer\">\n  <div class=\"custom-footer-inner\">\n\n    <!-- NEED HELP -->\n    <div>\n\n      <h3>Need Help</h3>\n\n      <div class=\"contact-item\">\n        <div class=\"contact-icon\">\n          <i class=\"fa-brands fa-whatsapp\"></i>\n        </div>\n\n        <div>\n          <div class=\"contact-title\">\n            <a href=\"https://wa.me/+919512969607\">\n              +91 9512969607\n            </a>\n          </div>\n\n          <div class=\"contact-time\">\n            Mon-Fri; 9am to 6pm\n          </div>\n        </div>\n      </div>\n\n      <div class=\"contact-item\">\n        <div class=\"contact-icon\">\n          <i class=\"fa-regular fa-envelope\"></i>\n        </div>\n\n        <div>\n          <div class=\"contact-title\">\n            <a href=\"mailto:care.lootlee@gmail.com\">\n              care.lootlee@gmail.com\n            </a>\n          </div>\n\n          <div class=\"contact-time\">\n            Mon-Fri; 9am to 6pm\n          </div>\n        </div>\n      </div>\n\n      <h3 class=\"social-heading\">\n        Connect with us\n      </h3>\n\n      <div class=\"social-icons\">\n\n        <a class=\"facebook\" href=\"YOUR_FACEBOOK_LINK_HERE\">\n          <i class=\"fa-brands fa-facebook\"></i>\n        </a>\n\n        <a class=\"whatsapp\" href=\"https://wa.me/+919512969607\">\n          <i class=\"fa-brands fa-whatsapp\"></i>\n        </a>\n\n        <a class=\"instagram\" href=\"YOUR_INSTAGRAM_LINK_HERE\">\n          <i class=\"fa-brands fa-instagram\"></i>